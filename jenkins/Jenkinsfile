pipeline {
    agent any

    environment {
        // Docker Hub / Container Registry
        DOCKER_REGISTRY = "docker.io"
        DOCKER_IMAGE_BACKEND = "techfest/backend"
        DOCKER_IMAGE_FRONTEND = "techfest/frontend"
        IMAGE_TAG = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"

        // Kubernetes
        K8S_NAMESPACE = "techfest"
        KUBECONFIG_CREDENTIAL = "kubeconfig-credentials"

        // Application
        APP_VERSION = "1.0.0"
        NODE_VERSION = "20"
    }

    options {
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps()
    }

    stages {
        // ── Stage 1: Checkout ─────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo '📦 Checking out source code...'
                checkout scm
                sh 'git log --oneline -5'
            }
        }

        // ── Stage 2: Validate Environment ─────────────────────────────────────
        stage('Validate Environment') {
            steps {
                echo '🔍 Validating build environment...'
                sh '''
                    node --version
                    npm --version
                    docker --version
                    docker compose version || true
                    kubectl version --client || true
                '''
            }
        }

        // ── Stage 3: Install Backend Dependencies ─────────────────────────────
        stage('Install Backend Dependencies') {
            steps {
                echo '📚 Installing backend dependencies...'
                dir('backend') {
                    sh 'npm ci --loglevel verbose'
                }
            }
        }

        // ── Stage 4: Install Frontend Dependencies ────────────────────────────
        stage('Install Frontend Dependencies') {
            steps {
                echo '📚 Installing frontend dependencies...'
                dir('frontend') {
                    sh 'npm ci --loglevel verbose'
                }
            }
        }

        // ── Stage 5: Lint ─────────────────────────────────────────────────────
        stage('Lint') {
            parallel {
                stage('Lint Backend') {
                    steps {
                        echo '🔎 Linting backend...'
                        dir('backend') {
                            sh 'npm run lint || true'
                        }
                    }
                }
                stage('Lint Frontend') {
                    steps {
                        echo '🔎 Linting frontend...'
                        dir('frontend') {
                            sh 'npm run lint || true'
                        }
                    }
                }
            }
        }

        // ── Stage 6: Run Tests ────────────────────────────────────────────────
        stage('Run Tests') {
            steps {
                echo '🧪 Running backend tests...'
                dir('backend') {
                    sh 'npm test -- --passWithNoTests --forceExit'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'backend/coverage/junit.xml'
                }
            }
        }

        // ── Stage 7: Build Frontend ───────────────────────────────────────────
        stage('Build Frontend') {
            steps {
                echo '🏗️ Building React frontend...'
                dir('frontend') {
                    sh '''
                        npm run build
                        echo "✅ Frontend build complete"
                        ls -la dist/
                    '''
                }
            }
        }

        // ── Stage 8: Build Backend ────────────────────────────────────────────
        stage('Build Backend') {
            steps {
                echo '🏗️ Compiling TypeScript backend...'
                dir('backend') {
                    sh '''
                        npx prisma generate
                        npm run build
                        echo "✅ Backend build complete"
                        ls -la dist/
                    '''
                }
            }
        }

        // ── Stage 9: Build Docker Images ──────────────────────────────────────
        stage('Build Docker Images') {
            steps {
                echo '🐳 Building Docker images...'
                script {
                    withCredentials([usernamePassword(
                        credentialsId: 'docker-hub-credentials',
                        usernameVariable: 'DOCKER_USERNAME',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )]) {
                        sh "docker login -u ${DOCKER_USERNAME} -p ${DOCKER_PASSWORD}"

                        // Backend image
                        sh """
                            docker build \\
                                -f docker/Dockerfile.backend \\
                                -t ${DOCKER_IMAGE_BACKEND}:${IMAGE_TAG} \\
                                -t ${DOCKER_IMAGE_BACKEND}:latest \\
                                ./backend
                        """

                        // Frontend image
                        sh """
                            docker build \\
                                -f docker/Dockerfile.frontend \\
                                -t ${DOCKER_IMAGE_FRONTEND}:${IMAGE_TAG} \\
                                -t ${DOCKER_IMAGE_FRONTEND}:latest \\
                                ./frontend
                        """

                        echo "✅ Docker images built: ${IMAGE_TAG}"
                    }
                }
            }
        }

        // ── Stage 10: Push Docker Images ──────────────────────────────────────
        stage('Push Docker Images') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                echo '📤 Pushing Docker images to registry...'
                script {
                    withCredentials([usernamePassword(
                        credentialsId: 'docker-hub-credentials',
                        usernameVariable: 'DOCKER_USERNAME',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )]) {
                        sh """
                            docker push ${DOCKER_IMAGE_BACKEND}:${IMAGE_TAG}
                            docker push ${DOCKER_IMAGE_BACKEND}:latest
                            docker push ${DOCKER_IMAGE_FRONTEND}:${IMAGE_TAG}
                            docker push ${DOCKER_IMAGE_FRONTEND}:latest
                        """
                        echo "✅ Images pushed to registry"
                    }
                }
            }
        }

        // ── Stage 11: Deploy to Kubernetes ────────────────────────────────────
        stage('Deploy to Kubernetes') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                echo '☸️ Deploying to Kubernetes cluster...'
                script {
                    withCredentials([file(credentialsId: KUBECONFIG_CREDENTIAL, variable: 'KUBECONFIG')]) {
                        // Apply all Kubernetes manifests
                        sh """
                            kubectl apply -f kubernetes/namespace.yaml
                            kubectl apply -f kubernetes/configmap.yaml
                            kubectl apply -f kubernetes/secret.yaml
                            kubectl apply -f kubernetes/pvc.yaml
                            kubectl apply -f kubernetes/deployments.yaml
                            kubectl apply -f kubernetes/services.yaml
                            kubectl apply -f kubernetes/hpa.yaml
                            kubectl apply -f kubernetes/ingress.yaml
                        """
                    }
                }
            }
        }

        // ── Stage 12: Update Image Tags ────────────────────────────────────────
        stage('Update Kubernetes Image Tags') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                echo '🏷️ Updating deployment image tags...'
                script {
                    withCredentials([file(credentialsId: KUBECONFIG_CREDENTIAL, variable: 'KUBECONFIG')]) {
                        sh """
                            kubectl set image deployment/backend \\
                                backend=${DOCKER_IMAGE_BACKEND}:${IMAGE_TAG} \\
                                -n ${K8S_NAMESPACE}

                            kubectl set image deployment/frontend \\
                                frontend=${DOCKER_IMAGE_FRONTEND}:${IMAGE_TAG} \\
                                -n ${K8S_NAMESPACE}
                        """
                    }
                }
            }
        }

        // ── Stage 13: Verify Deployment ───────────────────────────────────────
        stage('Verify Deployment') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                echo '✅ Verifying deployment rollout...'
                script {
                    withCredentials([file(credentialsId: KUBECONFIG_CREDENTIAL, variable: 'KUBECONFIG')]) {
                        sh """
                            kubectl rollout status deployment/backend -n ${K8S_NAMESPACE} --timeout=120s
                            kubectl rollout status deployment/frontend -n ${K8S_NAMESPACE} --timeout=60s
                            echo "All pods are running:"
                            kubectl get pods -n ${K8S_NAMESPACE}
                        """
                    }
                }
            }
        }
    }

    // ── Post Actions ──────────────────────────────────────────────────────────
    post {
        always {
            echo '🧹 Cleaning up Docker images...'
            sh """
                docker rmi ${DOCKER_IMAGE_BACKEND}:${IMAGE_TAG} || true
                docker rmi ${DOCKER_IMAGE_FRONTEND}:${IMAGE_TAG} || true
                docker system prune -f || true
            """
        }
        success {
            echo """
            ╔══════════════════════════════════════╗
            ║   ✅ BUILD & DEPLOY SUCCESSFUL!       ║
            ║   Build: #${env.BUILD_NUMBER}         ║
            ║   Tag: ${IMAGE_TAG}                   ║
            ╚══════════════════════════════════════╝
            """
        }
        failure {
            echo """
            ╔══════════════════════════════════════╗
            ║   ❌ BUILD FAILED!                    ║
            ║   Build: #${env.BUILD_NUMBER}         ║
            ║   Check logs above for details        ║
            ╚══════════════════════════════════════╝
            """
        }
    }
}
